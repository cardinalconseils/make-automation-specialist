{
  "name": "make-automation-specialist",
  "version": "1.5.1",
  "description": "Claude Code plugin that turns any project into an intelligent Make.com automation workspace. Conversational automation building, scenario auditing, compliance assessment, and observability.",
  "author": "pmcardinal",
  "license": "MIT",
  "mcps": {
    "required": [
      "make",
      "telnyx"
    ],
    "optional": [
      "supabase",
      "n8n",
      "github"
    ]
  },
  "env": {
    "required": [
      "MAKE_API_KEY",
      "MAKE_TEAM_ID"
    ],
    "optional": [
      "TELNYX_API_KEY",
      "TELNYX_ALERT_PHONE",
      "TELEGRAM_CHAT_ID",
      "SUPABASE_URL",
      "SUPABASE_KEY",
      "N8N_BASE_URL",
      "N8N_API_KEY",
      "GITHUB_TOKEN"
    ]
  },
  "agents": [
    {
      "id": "automation-specialist",
      "name": "Make.com Automation Specialist",
      "file": "agents/automation-specialist.md",
      "description": "Primary conversational agent. Discovers business needs, coordinates planning, presents plans for approval, and delegates execution.",
      "triggers": [
        "default",
        "slash:make",
        "slash:build"
      ]
    },
    {
      "id": "scenario-orchestrator",
      "name": "Scenario Orchestrator",
      "file": "agents/scenario-orchestrator.md",
      "description": "Full-lifecycle orchestrator. Runs Kickstart → Bootstrap → System Design → Sprint to build a portfolio of scenarios in one guided session.",
      "triggers": [
        "slash:factory",
        "slash:kickstart"
      ]
    },
    {
      "id": "scenario-auditor",
      "name": "Scenario Auditor",
      "file": "agents/scenario-auditor.md",
      "description": "Analyzes Make.com scenarios for issues, inefficiencies, and compliance risks. Proposes and executes fixes.",
      "triggers": [
        "slash:audit",
        "slash:fix"
      ]
    },
    {
      "id": "automation-planner",
      "name": "Automation Planner",
      "file": "agents/automation-planner.md",
      "description": "Pure plan generation. Takes a business requirement, produces an AutomationPlan with cost estimate, risk level, and step breakdown. Never executes.",
      "triggers": [
        "slash:plan"
      ]
    },
    {
      "id": "scenario-reporter",
      "name": "Scenario Reporter",
      "file": "agents/scenario-reporter.md",
      "description": "Generates visual Mermaid flowcharts and written reports for scenarios. Read-only — no MCP writes.",
      "triggers": [
        "slash:diagram",
        "slash:report"
      ]
    },
    {
      "id": "ai-agent-builder",
      "name": "AI Agent Builder",
      "file": "agents/ai-agent-builder.md",
      "description": "Designs and builds AI-powered agents inside Make.com scenarios. Guides model selection, tool inventory, memory strategy, and pattern choice — then produces a validated blueprint and builds with full approval gates.",
      "triggers": [
        "slash:agent",
        "slash:ai-agent",
        "slash:ai"
      ]
    },
    {
      "id": "telnyx-agent",
      "name": "Telnyx Communications Specialist",
      "file": "agents/telnyx-agent.md",
      "description": "Handles all SMS, voice, SIP trunking, AI assistants, WebRTC, phone number management, and Telnyx platform configuration. Activated by /telnyx, /sms, /voice or routed from automation-specialist.",
      "triggers": [
        "slash:telnyx",
        "slash:sms",
        "slash:voice"
      ]
    }
  ],
  "skills": [
    {
      "id": "core-behaviors",
      "file": "skills/core-behaviors/SKILL.md"
    },
    {
      "id": "project-discoverer",
      "file": "skills/project-discoverer/SKILL.md"
    },
    {
      "id": "kickstart-intake",
      "file": "skills/kickstart-intake/SKILL.md"
    },
    {
      "id": "plan-builder",
      "file": "skills/plan-builder/SKILL.md"
    },
    {
      "id": "sprint-runner",
      "file": "skills/sprint-runner/SKILL.md"
    },
    {
      "id": "scenario-reader",
      "file": "skills/scenario-reader/SKILL.md"
    },
    {
      "id": "diagram-generator",
      "file": "skills/diagram-generator/SKILL.md"
    },
    {
      "id": "compliance-scanner",
      "file": "skills/compliance-scanner/SKILL.md"
    },
    {
      "id": "cost-estimator",
      "file": "skills/cost-estimator/SKILL.md"
    },
    {
      "id": "alert-dispatcher",
      "file": "skills/alert-dispatcher/SKILL.md"
    },
    {
      "id": "execution-logger",
      "file": "skills/execution-logger/SKILL.md"
    },
    {
      "id": "memory",
      "file": "skills/memory/SKILL.md"
    },
    {
      "id": "database-builder",
      "file": "skills/database-builder/SKILL.md"
    },
    {
      "id": "connector-builder",
      "file": "skills/connector-builder/SKILL.md"
    },
    {
      "id": "mcp-builder",
      "file": "skills/mcp-builder/SKILL.md"
    },
    {
      "id": "persona-automation-consultant",
      "file": "skills/personas/automation-consultant.md"
    },
    {
      "id": "persona-project-manager",
      "file": "skills/personas/project-manager.md"
    },
    {
      "id": "persona-qa-engineer",
      "file": "skills/personas/qa-engineer.md"
    },
    {
      "id": "persona-solution-architect",
      "file": "skills/personas/solution-architect.md"
    },
    {
      "id": "persona-technical-writer",
      "file": "skills/personas/technical-writer.md"
    },
    {
      "id": "ai-agent-designer",
      "file": "skills/ai-agent-designer/SKILL.md"
    },
    {
      "id": "ai-docs-researcher",
      "file": "skills/ai-docs-researcher/SKILL.md"
    },
    {
      "id": "agent-pattern-library",
      "file": "skills/agent-pattern-library/SKILL.md"
    },
    {
      "id": "docs-researcher",
      "file": "skills/docs-researcher/SKILL.md"
    },
    {
      "id": "formula-expert",
      "file": "skills/formula-expert/SKILL.md"
    },
    {
      "id": "error-handler",
      "file": "skills/error-handler/SKILL.md"
    },
    {
      "id": "telnyx-expert",
      "file": "skills/telnyx-expert/SKILL.md"
    },
    {
      "id": "persona-telnyx-consultant",
      "file": "skills/personas/telnyx-consultant.md"
    }
  ],
  "hooks": [
    {
      "id": "on-project-open",
      "file": "hooks/on-project-open.md",
      "event": "project.open",
      "description": "Runs on first session open. Discovers MCPs, maps workspace, writes workspace.json."
    },
    {
      "id": "pre-execute",
      "file": "hooks/pre-execute.md",
      "event": "before.mcp.write",
      "description": "Approval gate enforcer. Halts any Make.com write MCP call until user confirms."
    },
    {
      "id": "post-execute",
      "file": "hooks/post-execute.md",
      "event": "after.mcp.call",
      "description": "Writes execution log and triggers Telegram alert on failure."
    },
    {
      "id": "on-error",
      "file": "hooks/on-error.md",
      "event": "error",
      "description": "Auto-recovery attempt, log write, and Telegram alert for unresolvable errors."
    },
    {
      "id": "on-session-end",
      "file": "hooks/on-session-end.md",
      "event": "session.stop",
      "description": "Writes session memory snapshot and appends decisions/gotchas to persistent memory files."
    },
    {
      "id": "on-sms-voice-context",
      "file": "hooks/on-sms-voice-context.md",
      "event": "before.agent.respond",
      "description": "Detects SMS, voice, and Telnyx-specific keywords in user messages and routes to telnyx-agent. Ignores Telegram-only context."
    }
  ],
  "output": {
    "root": ".make",
    "directories": [
      "plans",
      "logs",
      "scenarios",
      "changelog",
      "audits",
      "compliance",
      "diagrams",
      "factory",
      "context",
      "memory",
      "memory/sessions",
      "mcp-servers",
      "context/ai-agents"
    ]
  }
}
