# Make.com Automation Specialist — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ─────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────

# Make.com API key
# Get yours at: https://www.make.com/en/help/account/your-api-key
MAKE_API_KEY=

# Make.com Team ID
# Found in your Make.com team settings URL
MAKE_TEAM_ID=

# ─────────────────────────────────────────────
# REQUIRED FOR TELEGRAM ALERTS
# ─────────────────────────────────────────────

# Telnyx API key
# Get yours at: https://portal.telnyx.com
TELNYX_API_KEY=

# Telegram chat ID to send alerts to
# Get this by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────
# OPTIONAL — Add as needed
# ─────────────────────────────────────────────

# Supabase (for persistent storage)
SUPABASE_URL=
SUPABASE_KEY=

# n8n (fallback automation platform)
N8N_BASE_URL=
N8N_API_KEY=

# GitHub (read project context)
GITHUB_TOKEN=
